{
	"name": "gitrod",
	"version": "0.0.1",
	"description": "Electrobun app with React, Tailwind CSS, and Vite HMR",
	"scripts": {
		"dev": "concurrently \"bunx vite\" \"electrobun dev --watch\"",
		"build": "vite build && electrobun build",
		"lint": "biome check --write",
		"prepare": "husky"
	},
	"dependencies": {
		"electrobun": "1.16.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@tailwindcss/vite": "^4.2.2",
		"@types/bun": "latest",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"concurrently": "^9.2.1",
		"husky": "^9.1.7",
		"tailwindcss": "^4.2.2",
		"typescript": "~6.0.2",
		"vite": "^8.0.2"
	},
	"private": true
}
